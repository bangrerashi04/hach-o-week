<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Book</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #1d2671, #c33764);
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Glass Card */
.container {
    backdrop-filter: blur(15px);
    background: rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 30px;
    width: 380px;
    color: white;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    animation: fadeIn 1s ease;
}

h1 {
    text-align: center;
    margin-bottom: 20px;
}

/* Inputs */
input {
    width: 100%;
    padding: 12px;
    margin: 8px 0;
    border-radius: 10px;
    border: none;
    outline: none;
    background: rgba(255,255,255,0.2);
    color: white;
}

input::placeholder {
    color: #ddd;
}

/* Buttons */
button {
    width: 48%;
    padding: 10px;
    margin: 5px 1%;
    border: none;
    border-radius: 10px;
    background: linear-gradient(45deg, #ff512f, #dd2476);
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    transform: scale(1.05);
    background: linear-gradient(45deg, #24c6dc, #514a9d);
}

/* Full width button */
.full {
    width: 100%;
}

/* Contact List */
ul {
    list-style: none;
    padding: 0;
    max-height: 150px;
    overflow-y: auto;
}

li {
    background: rgba(255,255,255,0.2);
    margin: 5px 0;
    padding: 10px;
    border-radius: 10px;
    animation: slideIn 0.3s ease;
}

/* Result */
#result {
    margin-top: 10px;
    text-align: center;
    font-weight: bold;
}

/* Animations */
@keyframes fadeIn {
    from {opacity: 0; transform: scale(0.9);}
    to {opacity: 1; transform: scale(1);}
}

@keyframes slideIn {
    from {transform: translateX(-20px); opacity: 0;}
    to {transform: translateX(0); opacity: 1;}
}
</style>

</head>
<body>

<div class="container">
    <h1>📱 Contact Book</h1>

    <input type="text" id="name" placeholder="Enter Name">
    <input type="text" id="phone" placeholder="Enter Phone">

    <div>
        <button onclick="addContact()">Add</button>
        <button onclick="toggleContacts()">Show</button>
    </div>

    <input type="text" id="searchName" placeholder="Search Contact">

    <button class="full" onclick="searchContact()">Search</button>

    <p id="result"></p>

    <ul id="contactList"></ul>
</div>

<script>
let contacts = [];

function addContact() {
    let name = document.getElementById("name").value.trim();
    let phone = document.getElementById("phone").value.trim();

    if (name === "" || phone === "") {
        document.getElementById("result").textContent = "⚠️ Enter all fields";
        return;
    }

    contacts.push({ name: name.toLowerCase(), phone });

    document.getElementById("name").value = "";
    document.getElementById("phone").value = "";

    sortContacts();
}

function displayContacts() {
    let list = document.getElementById("contactList");
    list.innerHTML = "";

    contacts.forEach(c => {
        let li = document.createElement("li");
        li.textContent = `${c.name} - ${c.phone}`;
        list.appendChild(li);
    });
}

function sortContacts() {
    contacts.sort((a, b) => a.name.localeCompare(b.name));
    displayContacts();
}

function binarySearch(name) {
    let left = 0, right = contacts.length - 1;
    name = name.toLowerCase();

    while (left <= right) {
        let mid = Math.floor((left + right) / 2);
        let midName = contacts[mid].name;

        if (midName === name) return contacts[mid];
        if (midName < name) left = mid + 1;
        else right = mid - 1;
    }
    return null;
}

function searchContact() {
    let name = document.getElementById("searchName").value.trim();

    if (name === "") {
        document.getElementById("result").textContent = "⚠️ Enter name to search";
        return;
    }

    sortContacts();

    let result = binarySearch(name);

    if (result) {
        document.getElementById("result").textContent =
            `✅ Found: ${result.name} - ${result.phone}`;
    } else {
        document.getElementById("result").textContent =
            "❌ Contact not found";
    }
}

function toggleContacts() {
    let list = document.getElementById("contactList");
    list.style.display = list.style.display === "none" ? "block" : "none";
}
</script>

</body>
</html>
